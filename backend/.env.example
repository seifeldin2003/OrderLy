# Environment variables for Customer Ordering System

# Database
# For development: Use SQLite (local file)

DATABASE_URL=sqlite:///./customer_ordering.db

# JWT Authentication
# Change this to a strong random string in production
# You can generate one using: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Frontend Origins (CORS)
# Comma-separated list of allowed origins for your React frontend
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
